###############################################################################
# Line Endings & Text Normalization
###############################################################################
# Automatically normalize line endings to LF in the repo, CRLF/LF on checkout
* text=auto

# Ensure C++ source and header files use correct diff drivers
*.cpp   text diff=cpp
*.h     text diff=cpp
*.hpp   text diff=cpp

# Configuration files
*.cmake text
CMakeLists.txt text
*.json  text
*.md    text

###############################################################################
# Binary Files
###############################################################################
# PNG images and icons are strictly binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary

# Executables and libraries
*.exe   binary
*.dll   binary
*.lib   binary
*.a     binary
*.so    binary
